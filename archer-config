#! /bin/bash

# Archer Configuration Toolkit is a modular and easy way to setup and configure different parts of your Arch Linux system
# Select one or more arrows from the quiver and Archer Configuration Toolkit will install and configure features for your system automatically

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
QUIVER="${SCRIPT_DIR}/quiver"
export SCRIPT_DIR QUIVER

# Helper functions #
show_info() {
    echo "$(tput setaf 4)$(tput bold)> $*$(tput sgr0)"
}
export -f show_info
# Helper functions #

# Source bash-tui-toolkit
if ! [[ -f $SCRIPT_DIR/bash-tui-toolkit.bash ]]; then
    if ! curl -fsSL https://bash-tui-toolkit.timo-reymann.de/latest/bundle.bash -o "$SCRIPT_DIR/bash-tui-toolkit.bash"; then
        echo "Failed downloading bash-tui-toolkit"
        exit 1
    fi
fi
source "$SCRIPT_DIR/bash-tui-toolkit.bash"

# Export bash-tui-toolkit functions for arrows to use
mapfile -t toolkit_functions < <(
    grep -E '^[[:space:]]*[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*\(\)' "$SCRIPT_DIR"/bash-tui-toolkit.bash | sed -E 's/^[[:space:]]*([^ (]+).*/\1/'
)
export -f "${toolkit_functions[@]}"

confirmed=0
while [ "$confirmed" = 0 ]; do
    modules=()
    display=()

    clear
    echo -e "
-------------------------------------------------------------------------
$(tput setaf 4)
             в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
            в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—
            в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ
            в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—
            в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘
            в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ
$(tput sgr0)
-------------------------------------------------------------------------
                          Configuration Toolkit
-------------------------------------------------------------------------"

    # Get arrows
    while IFS= read -r file; do
        modules+=("$file")

        name=$(grep '^# NAME:' "$file" | sed 's/# NAME: //')
        desc=$(grep '^# DESC:' "$file" | sed 's/# DESC: //')
        [ -z "$name" ] && name=$(basename "$file")
        [ -z "$desc" ] && desc="No description available"

        display+=("${name} - ${desc}")
    done < <(find "$QUIVER" -maxdepth 1 -type f | sort)

    if [ "${#display[@]}" -eq 0 ]; then
        show_error "No arrows found in the quiver"
        exit 1
    fi

    selected=$(checkbox "Select arrows to fire" "${display[@]}")
    echo

    if [ -z "$selected" ]; then
        show_error "You must select at least one arrow"
        sleep 0.5
        continue
    fi

    confirmed=$(confirm "Fire selected arrows?")
    echo
done


for index in $selected; do
    module="${modules[$index]}"

    echo "-------------------------------------------------------------------------"
    show_info "Firing $(basename "$module") arrow"

    if bash "$module"; then
        show_success "$(basename "$module") hit the target"
    else
        show_error "$(basename "$module") missed the target"
    fi
done

show_success "Done! All arrows have been fired"
show_info "Please reboot your system"
confirmed=$(confirm "Would you like to reboot now?")
[[ $confirmed == 1 ]] && reboot
[[ $confirmed == 0 ]] && exit
